import heapq

graph = {
    'A': ['B', 'C'],
    'B': ['D', 'E'],
    'C': ['F'],
    'D': [],
    'E': [],
    'F': []
}

heuristic = {
    'A': 6,
    'B': 4,
    'C': 2,
    'D': 5,
    'E': 1,
    'F': 0
}

visited = set()
pq = [(heuristic['A'], 'A')]

print("Best First Search:")

while pq:
    h, node = heapq.heappop(pq)

    if node not in visited:
        visited.add(node)
        print(node)

        for i in graph[node]:
            heapq.heappush(pq, (heuristic[i], i))
